# ─── Required ──────────────────────────
ARGUS_BOT_TOKEN=              # Telegram bot token from @BotFather
ANTHROPIC_API_KEY=            # Claude API key (for brain + stock-strategist)

# ─── Trading Mode ──────────────────────
ARGUS_PAPER_TRADING=true      # true = log signals only, no trades
ARGUS_TESTNET=false           # true = use testnet RPCs + HL testnet

# ─── Wallet (not needed for paper trading) ──
# ARGUS_WALLET_KEY=           # Arbitrum private key (hex, no 0x prefix)

# ─── RPC (optional, has public defaults) ──
# ARBITRUM_RPC_URL=
# ETHEREUM_RPC_URL=

# ─── Monitoring (optional) ─────────────
# HEALTHCHECKS_PING_URL=
# PUSHOVER_USER_KEY=
# PUSHOVER_APP_TOKEN=

# ─── Local Bot API (if running on OpenClaw) ──
# TELEGRAM_API_URL=http://localhost:8081
