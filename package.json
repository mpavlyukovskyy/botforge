{
  "name": "botforge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Agent management platform \u2014 run, monitor, and manage AI agents at scale",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @botforge/cli dev",
