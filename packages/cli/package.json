{
  "name": "@botforge/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "botforge": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@botforge/core": "workspace:*",
    "@botforge/adapter-telegram": "workspace:*",
    "@botforge/storage-sqlite": "workspace:*",
    "@botforge/skill-conversation-history": "workspace:*",
    "@botforge/skill-token-tracker": "workspace:*",
    "@botforge/skill-context-builder": "workspace:*",
    "@botforge/skill-circuit-breaker": "workspace:*",
    "@botforge/skill-passive-detection": "workspace:*",
    "@botforge/skill-cron-scheduler": "workspace:*",
    "@botforge/skill-daily-digest": "workspace:*",
    "@botforge/skill-event-bus": "workspace:*",
    "@botforge/skill-health-server": "workspace:*",
    "@botforge/skill-pending-questions": "workspace:*",
    "@botforge/skill-tool-server": "workspace:*",
    "@botforge/skill-reply-context": "workspace:*",
    "@botforge/skill-response-formatter": "workspace:*",
    "commander": "^13.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
